<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>YK</title>
<meta name="theme-color" content="#ff3b5c"/>
<link href="https://fonts.googleapis.com/css2?family=Coming+Soon&display=swap" rel="stylesheet">
<style>
:root{--accent:#ff3b5c;--accent-dim:#ff3b5c44;}
*{margin:0;padding:0;user-select:none;box-sizing:border-box;}
body{background:#000;color:#fff;font-family:'Coming Soon',cursive;min-height:100vh;overflow:hidden;display:flex;justify-content:center;align-items:center;}
#blur-overlay{position:fixed;inset:0;backdrop-filter:blur(8px);background:rgba(0,0,0,0.82);display:flex;flex-direction:column;justify-content:center;align-items:center;z-index:1000;color:#fff;font-size:2.5em;text-shadow:0 0 6px #000;cursor:pointer;}
#blur-overlay span{font-size:0.5em;margin-top:-12px;opacity:0.8;color:#a3a3a3;}
#trail-canvas,#sparkle-canvas{position:fixed;inset:0;pointer-events:none;}
#sparkle-canvas{z-index:2;}#trail-canvas{z-index:4;}
#copyright{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);color:#fff;font-size:0.9em;text-shadow:0 0 6px #fff;z-index:10;white-space:nowrap;}
#main-content{display:none;z-index:5;width:90%;max-width:420px;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);overflow-y:auto;max-height:90vh;}
.player-card{background:rgba(255,255,255,0.03);backdrop-filter:blur(25px) saturate(180%);border:2px solid var(--accent);border-radius:20px;padding:24px;box-shadow:0 12px 40px rgba(0,0,0,0.6),0 0 80px var(--accent-dim);}
.profile-top{display:flex;align-items:flex-start;gap:16px;margin-bottom:12px;}
.avatar-wrapper{position:relative;width:80px;height:80px;flex-shrink:0;}
.avatar{width:100%;height:100%;object-fit:cover;border-radius:50%;position:absolute;inset:0;z-index:1;}
.decoration{position:absolute;z-index:2;width:130%;height:130%;top:50%;left:50%;transform:translate(-50%,-50%);object-fit:contain;pointer-events:none;}
.status-dot-pfp{position:absolute;bottom:2px;right:2px;width:16px;height:16px;border-radius:50%;border:3px solid #000;z-index:3;}
.disc-badge{width:20px;height:20px;object-fit:contain;cursor:pointer;transition:transform 0.15s;}
.disc-badge:hover{transform:scale(1.2);}
#badgeTooltip{position:fixed;background:rgba(0,0,0,0.92);border:1px solid rgba(255,255,255,0.15);color:#fff;font-size:11px;padding:5px 10px;border-radius:8px;pointer-events:none;z-index:9999;white-space:nowrap;display:none;}
.disc-badges{display:flex;gap:4px;flex-wrap:wrap;margin-top:4px;}
.clan-tag{display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:6px;padding:2px 8px;font-size:12px;font-weight:700;letter-spacing:0.05em;}
.clan-badge-img{width:14px;height:14px;object-fit:contain;}
.name-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.username{font-size:28px;font-weight:bold;text-shadow:0 0 12px var(--accent-dim);}
#rp{margin-top:10px;}
.rp-box{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:10px 12px;display:flex;align-items:flex-start;gap:10px;}
.rp-label{font-size:10px;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;font-weight:700;}
.rp-art-wrap{position:relative;flex-shrink:0;}
.rp-large{width:56px;height:56px;border-radius:8px;object-fit:cover;}
.rp-small{position:absolute;bottom:-4px;right:-4px;width:20px;height:20px;border-radius:50%;border:2px solid rgba(10,10,14,0.9);}
.rp-text{flex:1;min-width:0;display:flex;flex-direction:column;gap:2px;}
.rp-name{font-size:13px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.rp-detail{font-size:11px;color:rgba(255,255,255,0.65);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.rp-state{font-size:11px;color:rgba(255,255,255,0.45);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.rp-elapsed{font-size:10px;color:rgba(255,255,255,0.35);margin-top:2px;}
.rp-spotify-bar{margin-top:6px;height:3px;background:rgba(255,255,255,0.15);border-radius:2px;overflow:hidden;}
.rp-spotify-fill{height:100%;background:#1db954;border-radius:2px;transition:width .9s linear;}
.quote-wrapper{background:rgba(0,0,0,0.5);border-radius:10px;padding:8px 14px;max-width:200px;min-height:36px;display:flex;align-items:center;overflow:hidden;}
.quote{font-size:15px;font-style:italic;color:rgba(255,255,255,0.9);white-space:nowrap;}
.badges-and-quote{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-top:6px;}
#waveform{width:100%;height:80px;margin:16px 0;border-radius:12px;background:rgba(0,0,0,0.5);display:block;}
.controls{display:flex;align-items:center;gap:12px;margin-bottom:12px;flex-wrap:wrap;justify-content:center;}
.btn,.vb{width:40px;height:40px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);border-radius:12px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all 0.2s;}
.btn:hover,.vb:hover{background:rgba(255,255,255,0.15);transform:scale(1.08);}
.btn.play-pause{width:48px;height:48px;}
.vb svg,.btn svg{width:24px;height:24px;fill:white;}
.track-info{flex:1;min-width:140px;text-align:center;display:flex;flex-direction:column;align-items:center;}
.track-name-el{font-size:14px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px;}
.track-artist-el{font-size:12px;color:rgba(255,255,255,0.6);margin-bottom:4px;}
.progress-wrapper{width:100%;margin-top:4px;}
.progress-time{font-size:12px;color:rgba(255,255,255,0.8);text-align:center;margin-bottom:6px;}
.progress-track{position:relative;height:4px;background:rgba(255,255,255,0.15);border-radius:2px;}
.progress-fill{position:absolute;top:0;left:0;height:100%;width:0%;background:linear-gradient(90deg,var(--accent),#fff);border-radius:2px;pointer-events:none;}
#progressSlider{-webkit-appearance:none;appearance:none;position:absolute;top:50%;left:0;transform:translateY(-50%);width:100%;height:20px;margin:0;background:transparent;outline:none;cursor:pointer;z-index:2;}
#progressSlider::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%;background:var(--accent);cursor:pointer;}
#progressSlider::-moz-range-thumb{width:18px;height:18px;border-radius:50%;background:var(--accent);border:none;cursor:pointer;}
.volume-area{display:flex;align-items:center;gap:12px;width:220px;}
.volume-container{position:relative;height:4px;flex:1;background:rgba(255,255,255,0.15);border-radius:2px;}
#volumeSlider{-webkit-appearance:none;appearance:none;width:100%;height:4px;background:transparent;outline:none;margin:0;cursor:pointer;position:absolute;top:4px;left:0;z-index:2;}
#volumeSlider::-webkit-slider-thumb{-webkit-appearance:none;width:24px;height:24px;background:var(--accent);border-radius:50%;cursor:pointer;margin-top:-8px;}
#volumeSlider::-moz-range-thumb{width:24px;height:24px;background:var(--accent);border-radius:50%;cursor:pointer;border:none;}
.volume-fill{position:absolute;top:0;left:0;height:100%;width:100%;background:linear-gradient(90deg,var(--accent),#fff);border-radius:2px;z-index:1;pointer-events:none;}
.socials{display:flex;justify-content:center;gap:14px;margin-top:20px;flex-wrap:wrap;}
.socials a{width:44px;height:44px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;transition:all 0.3s;}
.socials a:hover{transform:translateY(-4px);box-shadow:0 8px 20px var(--accent-dim);border-color:var(--accent);}
@media(max-width:500px){.player-card{padding:16px;}.avatar-wrapper{width:64px;height:64px;}.username{font-size:22px;}}
</style>
</head>
<body>

<div id="blur-overlay">Click to Enter<span>&#9888; site contains audio &nbsp;&middot;&nbsp; 100% safe</span></div>
<canvas id="sparkle-canvas"></canvas>
<canvas id="trail-canvas"></canvas>
<div id="main-content">
  <div class="player-card">
    <div class="profile-top">
      <div class="avatar-wrapper">
        <img class="avatar" src="data:image/png;base64," alt="YK"/>
        <img class="decoration" src="https://img.avatardecoration.com/decorations/hood_dark.png" alt=""/>
        <div class="status-dot-pfp" id="statusDot" style="background:#23a55a"></div>
      </div>
      <div style="flex:1;min-width:0;">
        <div class="name-row">
          <div class="username">YK</div>
          <div id="clanTagEl"><span class="clan-tag"><img src="https://cdn.discordapp.com/clan-badges/1479103119114764351/b1a70b12c9fc93280fd0f46b4365019c.png" class="clan-badge-img" onerror="this.style.display='none'"/>BLED</span></div>
        </div>
        <div class="disc-badges"><img src="https://static.wikia.nocookie.net/discord/images/1/16/Nitro_Badge_Platinum.png/revision/latest" data-name="Nitro (1 Year)" class="disc-badge" onclick="showBadgeName(this)"/><img src="https://static.wikia.nocookie.net/discord/images/c/c8/Server_Booster_3_Months.png/revision/latest" data-name="Server Booster (3 Months)" class="disc-badge" onclick="showBadgeName(this)"/></div>
        <div class="badges-and-quote" style="margin-top:6px;">
          <div class="quote-wrapper"><div class="quote" id="quoteEl"></div></div>
        </div>
      </div>
    </div>
    <div id="rp"></div>
    <canvas id="waveform"></canvas>
    <div class="controls">
      <div class="btn" id="prev"><svg viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg></div>
      <div class="btn play-pause" id="playPause"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
      <div class="btn" id="next"><svg viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg></div>
      <div class="track-info">
        <div class="track-name-el" id="trackName"></div>
        <div class="track-artist-el" id="trackArtist"></div>
        <div class="progress-wrapper">
          <div class="progress-time" id="progressTime">0:00 / 0:00</div>
          <div class="progress-track">
            <div class="progress-fill" id="progressFill"></div>
            <input type="range" id="progressSlider" min="0" max="1000" value="0"/>
          </div>
        </div>
      </div>
      <div class="volume-area">
        <div class="vb" id="vlb"><svg viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg></div>
        <div class="volume-container">
          <div class="volume-fill" id="volumeFill"></div>
          <input type="range" id="volumeSlider" min="0" max="100" value="100"/>
        </div>
      </div>
    </div>
    <div class="socials"><a href="https://open.spotify.com/user/312szs6omz66wuo3cvc4wzyrslqe" target="_blank" title="Spotify"><svg viewBox="0 0 24 24" width="22" height="22" fill="white"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg></a><a href="https://guns.lol/y9v2" target="_blank" title="Website"><svg viewBox="0 0 24 24" width="22" height="22" fill="white"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.22.2-1.8L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg></a></div>
  </div>
</div>
<div id="copyright">&copy; 2026 YK. All rights reserved.</div>
<div id="badgeTooltip"></div>
<audio id="playerAudio" preload="auto" crossorigin="anonymous"></audio>
<script>
(function(){
var TRACKS=[{"name":"MY JEALOUSY","artist":"...","src":"https://files.catbox.moe/dmdolp.mp3"}];
var ACCENT_RGB="255,59,92";
var LANYARD_UID="1266196994246840406";
var BIO="If you tell the truth, you don't have to remember anything.";
var cur=0,playing=false,fi=null,FADE=400,STEPS=20;
var audio=document.getElementById('playerAudio');
var ppBtn=document.getElementById('playPause');
var tName=document.getElementById('trackName');
var tArtist=document.getElementById('trackArtist');
var pTime=document.getElementById('progressTime');
var pFill=document.getElementById('progressFill');
var pSlider=document.getElementById('progressSlider');
var vSlider=document.getElementById('volumeSlider');
var vFill=document.getElementById('volumeFill');
var vlb=document.getElementById('vlb');
var ICON_PLAY='<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
var ICON_PAUSE='<svg viewBox="0 0 24 24"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>';
var ICON_VOL='<svg viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>';
var ICON_MUTE='<svg viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3 3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4 9.91 6.09 12 8.18V4z"/></svg>';
vlb.innerHTML=ICON_VOL;
function fmt(s){var m=Math.floor(s/60),x=Math.floor(s%60);return m+':'+(x<10?'0':'')+x;}
function volVal(){return parseFloat(vSlider.value)/100;}
function updateVolUI(){vFill.style.width=(audio.volume*100)+'%';}
function loadTrack(i){audio.src=TRACKS[i].src;tName.textContent=TRACKS[i].name;tArtist.textContent=TRACKS[i].artist;audio.load();audio.volume=volVal();updateVolUI();}
function fadeIn(cb){clearInterval(fi);var s=0,t=audio.muted?0:volVal(),ss=t/STEPS;fi=setInterval(function(){s++;audio.volume=Math.min(t,s*ss);if(s>=STEPS){clearInterval(fi);audio.volume=t;cb&&cb();}},FADE/STEPS);}
function fadeOut(cb){clearInterval(fi);var s=0,sv=audio.volume,ss=sv/STEPS;if(!sv){cb&&cb();return;}fi=setInterval(function(){s++;audio.volume=Math.max(0,sv-s*ss);if(s>=STEPS){clearInterval(fi);audio.volume=0;cb&&cb();}},FADE/STEPS);}
loadTrack(0);
ppBtn.onclick=function(){
  if(playing){fadeOut(function(){audio.pause();ppBtn.innerHTML=ICON_PLAY;playing=false;});}
  else{audio.play().catch(function(){});fadeIn(function(){ppBtn.innerHTML=ICON_PAUSE;playing=true;});}
};
document.getElementById('prev').onclick=function(){
  if(audio.currentTime>3){audio.currentTime=0;return;}
  cur=(cur-1+TRACKS.length)%TRACKS.length;
  fadeOut(function(){loadTrack(cur);if(playing){audio.play().catch(function(){});fadeIn(null);}});
};
document.getElementById('next').onclick=function(){
  cur=(cur+1)%TRACKS.length;
  fadeOut(function(){loadTrack(cur);if(playing){audio.play().catch(function(){});fadeIn(null);}});
};
audio.ontimeupdate=function(){
  if(!audio.duration)return;
  var p=audio.currentTime/audio.duration;
  pFill.style.width=(p*100)+'%';
  pSlider.value=Math.round(p*1000);
  pTime.textContent=fmt(audio.currentTime)+' / '+fmt(audio.duration);
};
pSlider.addEventListener('input',function(){
  if(audio.duration){var t=(pSlider.value/1000)*audio.duration;audio.currentTime=t;pFill.style.width=(pSlider.value/10)+'%';}
});
vSlider.addEventListener('input',function(){audio.volume=volVal();vFill.style.width=vSlider.value+'%';});
vlb.onclick=function(){audio.muted=!audio.muted;vlb.innerHTML=audio.muted?ICON_MUTE:ICON_VOL;if(!audio.muted)audio.volume=volVal();};
audio.onended=function(){cur=(cur+1)%TRACKS.length;fadeOut(function(){loadTrack(cur);if(playing){audio.play().catch(function(){});fadeIn(null);}});};

/* WAVEFORM */
var wfc=document.getElementById('waveform'),wfx=wfc.getContext('2d'),aCtx,anlz,vis=false;
function initVis(){if(vis)return;try{aCtx=new(window.AudioContext||window.webkitAudioContext)();anlz=aCtx.createAnalyser();anlz.fftSize=512;var src=aCtx.createMediaElementSource(audio);src.connect(anlz);anlz.connect(aCtx.destination);vis=true;drawWf();}catch(e){}}
function drawWf(){requestAnimationFrame(drawWf);if(!anlz)return;wfc.width=wfc.offsetWidth||400;wfc.height=wfc.offsetHeight||80;var buf=anlz.frequencyBinCount,d=new Uint8Array(buf),bw=(wfc.width/buf)*1.8,x=0;anlz.getByteFrequencyData(d);for(var k=0;k<buf;k++){var h=(d[k]/255)*wfc.height*0.85,g=wfx.createLinearGradient(0,wfc.height-h,0,wfc.height);g.addColorStop(0,'rgba('+ACCENT_RGB+',1)');g.addColorStop(0.5,'rgba(255,255,255,0.6)');g.addColorStop(1,'rgba(0,0,0,0.8)');wfx.fillStyle=g;wfx.fillRect(x,wfc.height-h,bw,h);x+=bw+1;}}

/* BADGE TOOLTIP */
var tip=document.getElementById('badgeTooltip');
window.showBadgeName=function(el){var r=el.getBoundingClientRect();tip.textContent=el.dataset.name;tip.style.cssText='position:fixed;display:block;left:'+r.left+'px;top:'+(r.top-34)+'px;';setTimeout(function(){tip.style.display='none';},1800);};

/* QUOTE TYPER */
var qEl=document.getElementById('quoteEl'),qt=BIO,qi=0,qd=false;
function typeQ(){if(!qt)return;if(!qd){qEl.textContent=qt.slice(0,++qi);if(qi===qt.length){setTimeout(function(){qd=true;setTimeout(typeQ,2000);},0);return;}}else{qEl.textContent=qt.slice(0,--qi);if(qi===0)qd=false;}setTimeout(typeQ,qd?40:80);}
if(qt)setTimeout(typeQ,600);

/* TRAIL + SPARKLES */
var tc=document.getElementById('trail-canvas'),tx=tc.getContext('2d');
var sc=document.getElementById('sparkle-canvas'),sx=sc.getContext('2d');
function rsz(){tc.width=sc.width=innerWidth;tc.height=sc.height=innerHeight;}rsz();
window.addEventListener('resize',rsz);
var pts=[],sparks=[];
document.addEventListener('mousemove',function(e){pts.push({x:e.clientX,y:e.clientY,t:Date.now()});});
setInterval(function(){sparks.push({x:Math.random()*innerWidth,y:Math.random()*innerHeight*0.6,r:Math.random()*2+1,t:Date.now()});},400);
(function loop(){
  var now=Date.now();
  tx.clearRect(0,0,tc.width,tc.height);
  for(var j=pts.length-1;j>0;j--){var a=1-(now-pts[j].t)/800;if(a<=0){pts.splice(0,j+1);break;}tx.beginPath();tx.moveTo(pts[j-1].x,pts[j-1].y);tx.lineTo(pts[j].x,pts[j].y);tx.strokeStyle='rgba('+ACCENT_RGB+','+a+')';tx.lineWidth=2;tx.stroke();}
  sx.clearRect(0,0,sc.width,sc.height);
  for(var i=sparks.length-1;i>=0;i--){var b=1-(now-sparks[i].t)/1500;if(b<=0){sparks.splice(i,1);continue;}sx.fillStyle='rgba('+ACCENT_RGB+','+b+')';sx.beginPath();sx.arc(sparks[i].x,sparks[i].y,sparks[i].r,0,Math.PI*2);sx.fill();}
  requestAnimationFrame(loop);
})();

/* LIVE RICH PRESENCE via Lanyard WS */
var STATUS_COLORS={online:'#23a55a',idle:'#f0b232',dnd:'#f23f43',offline:'#80848e'};
var rpWs,rpHb,rpTick;
function assetUrl(id,img){if(!img)return'';if(img.startsWith('mp:external/'))return'https://media.discordapp.net/external/'+img.slice(12);if(img.startsWith('https://'))return img;return id?'https://cdn.discordapp.com/app-assets/'+id+'/'+img+'.png':'';}
function updateStatus(s){var d=document.getElementById('statusDot');if(d)d.style.background=STATUS_COLORS[s]||STATUS_COLORS.offline;}
function updateClan(u){var el=document.getElementById('clanTagEl');if(!el)return;var pg=u&&u.primary_guild;if(pg&&pg.tag){var bi=pg.badge&&pg.identity_guild_id?'https://cdn.discordapp.com/clan-badges/'+pg.identity_guild_id+'/'+pg.badge+'.png':'';el.innerHTML='<span class="clan-tag">'+(bi?'<img src="'+bi+'" class="clan-badge-img" onerror="this.style.display=\'none\'"/>' :'')+pg.tag+'</span>';}else{el.innerHTML='';}}
function renderRP(d){
  var el=document.getElementById('rp');if(!el||!d)return;
  if(d.discord_status)updateStatus(d.discord_status);
  if(d.discord_user)updateClan(d.discord_user);
  var sp=d.listening_to_spotify?d.spotify:null,acts=d.activities||[],game=null,stream=null,custom=null;
  acts.forEach(function(a){if(a.type===0&&!game)game=a;if(a.type===1&&!stream)stream=a;if(a.type===4&&!custom)custom=a;});
  clearInterval(rpTick);
  if(sp){
    var pct=sp.timestamps?Math.min(100,(Date.now()-sp.timestamps.start)/(sp.timestamps.end-sp.timestamps.start)*100):0;
    el.innerHTML='<div class="rp-label">Listening to Spotify</div><div class="rp-box">'+(sp.album_art_url?'<div class="rp-art-wrap"><img class="rp-large" src="'+sp.album_art_url+'" onerror="this.style.display=\'none\'"/><img class="rp-small" src="https://i.imgur.com/OFy4tqH.png" style="background:#1db954"/></div>':'')+'<div class="rp-text"><div class="rp-name">'+sp.song+'</div><div class="rp-detail">by '+sp.artist+'</div><div class="rp-state">on '+sp.album+'</div><div class="rp-spotify-bar"><div class="rp-spotify-fill" id="spBar" style="width:'+pct+'%"></div></div></div></div>';
    if(sp.timestamps)rpTick=setInterval(function(){var b=document.getElementById('spBar');if(b)b.style.width=Math.min(100,(Date.now()-sp.timestamps.start)/(sp.timestamps.end-sp.timestamps.start)*100)+'%';},1000);
  }else if(game||stream){
    var act=game||stream,id=act.application_id,ts=act.timestamps&&act.timestamps.start;
    var lu=assetUrl(id,act.assets&&act.assets.large_image)||(id?'https://dcdn.dstn.to/app-icons/'+id:'');
    var su=assetUrl(id,act.assets&&act.assets.small_image);
    var art=lu?'<div class="rp-art-wrap"><img class="rp-large" src="'+lu+'" onerror="this.style.display=\'none\'"/>'+(su?'<img class="rp-small" src="'+su+'" onerror="this.style.display=\'none\'"/>':'')+'</div>':'';
    function el2(t){return Math.floor((Date.now()-t)/60000)+':'+(Math.floor((Date.now()-t)/1000%60)<10?'0':'')+Math.floor((Date.now()-t)/1000%60);}
    el.innerHTML='<div class="rp-label">'+(act.type===1?'Streaming':'Playing a Game')+'</div><div class="rp-box">'+art+'<div class="rp-text"><div class="rp-name">'+act.name+'</div>'+(act.details?'<div class="rp-detail">'+act.details+'</div>':'')+(act.state?'<div class="rp-state">'+act.state+'</div>':'')+(ts?'<div class="rp-elapsed" id="rpEl">'+el2(ts)+' elapsed</div>':'')+'</div></div>';
    if(ts)rpTick=setInterval(function(){var e=document.getElementById('rpEl');if(e)e.textContent=el2(ts)+' elapsed';},1000);
  }else if(custom&&(custom.state||custom.emoji)){
    var em='';if(custom.emoji){em=custom.emoji.id?'<img src="https://cdn.discordapp.com/emojis/'+custom.emoji.id+'.'+(custom.emoji.animated?'gif':'png')+'" style="width:16px;height:16px;vertical-align:middle;margin-right:4px"/>':'<span style="margin-right:4px">'+custom.emoji.name+'</span>';}
    el.innerHTML='<div class="rp-box"><div class="rp-text"><div class="rp-detail">'+em+(custom.state||'')+'</div></div></div>';
  }else{el.innerHTML='';}
}
if(LANYARD_UID){
  (function wsConnect(){
    try{
      rpWs=new WebSocket('wss://api.lanyard.rest/socket');
      rpWs.onmessage=function(e){try{var m=JSON.parse(e.data);if(m.op===1)rpHb=setInterval(function(){if(rpWs.readyState===1)rpWs.send(JSON.stringify({op:3}));},m.d.heartbeat_interval);if(m.op===0&&m.t==='INIT_STATE'){var d=m.d[LANYARD_UID];if(d)renderRP(d);}if(m.op===0&&m.t==='PRESENCE_UPDATE'&&m.d.user_id===LANYARD_UID)renderRP(m.d);}catch(x){}};
      rpWs.onopen=function(){rpWs.send(JSON.stringify({op:2,d:{subscribe_to_id:LANYARD_UID}}));};
      rpWs.onclose=function(){clearInterval(rpHb);setTimeout(wsConnect,3000);};
      rpWs.onerror=function(){rpWs.close();};
    }catch(x){}
  })();
}

/* CLICK TO ENTER */
var ov=document.getElementById('blur-overlay'),mc=document.getElementById('main-content');
ov.addEventListener('click',function go(){
  ov.removeEventListener('click',go);
  ov.style.transition='opacity 0.7s';ov.style.opacity='0';
  setTimeout(function(){
    ov.style.display='none';mc.style.display='block';mc.style.opacity='0';mc.style.transition='opacity 0.4s';
    requestAnimationFrame(function(){requestAnimationFrame(function(){
      mc.style.opacity='1';
      audio.muted=false;audio.volume=volVal();vlb.innerHTML=ICON_VOL;updateVolUI();
      audio.play().catch(function(){});playing=true;ppBtn.innerHTML=ICON_PAUSE;
      initVis();
    });});
  },750);
});
})();
</script>
</body>
</html>
