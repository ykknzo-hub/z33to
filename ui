-- Drag functionality
local dragging = false
local dragStart = nil
local startPos = nil

topBar.InputBegan:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = UserInputService:GetMouseLocation()
		startPos = uiWindow.Position
	end
end)

topBar.InputEnded:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

RunService.RenderStepped:Connect(function()
	if dragging and dragStart and startPos then
		local currentMouse = UserInputService:GetMouseLocation()
		local delta = currentMouse - dragStart
		
		uiWindow.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- Keyboard Shortcut (B to toggle)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.B then
		screenGui.Enabled = not screenGui.Enabled
	end
end)
