for i, buttonName in ipairs(allButtonNames) do
	print("[Z33TO] Creating button: " .. buttonName)
	local sideBtn = Instance.new("TextButton")
	sideBtn.Name = buttonName .. "Btn"
	sideBtn.Size = UDim2.new(1, 0, 0, 28)
	sideBtn.BackgroundColor3 = Color3.fromRGB(200, 150, 200)
	sideBtn.BackgroundTransparency = 0.5
	sideBtn.BorderSizePixel = 0
	sideBtn.Text = buttonName
	sideBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	sideBtn.TextSize = 11
	sideBtn.Font = Enum.Font.GothamBold
	sideBtn.LayoutOrder = i
	sideBtn.Parent = leftSidebar
	sideBtn.ZIndex = 12
	sideBtn.Visible = true
	
	local sideCorner = Instance.new("UICorner")
	sideCorner.CornerRadius = UDim.new(0, 4)
	sideCorner.Parent = sideBtn
	
	sideBtn.MouseButton1Click:Connect(function()
		print("[Z33TO] Clicked: " .. buttonName)
		
		if selectedButton then
			selectedButton.BackgroundColor3 = Color3.fromRGB(200, 150, 200)
			selectedButton.BackgroundTransparency = 0.5
		end
		
		sideBtn.BackgroundColor3 = Color3.fromRGB(200, 150, 200)
		sideBtn.BackgroundTransparency = 0.2
		selectedButton = sideBtn
		
		showPage(buttonName)
	end)
	
	sideBtn.MouseEnter:Connect(function()
		if sideBtn ~= selectedButton then
			sideBtn.BackgroundTransparency = 0.3
		end
	end)
	
	sideBtn.MouseLeave:Connect(function()
		if sideBtn ~= selectedButton then
			sideBtn.BackgroundTransparency = 0.5
		end
	end)
end

