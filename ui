			-- Update slider fill based on value
			local function updateSlider(value)
				local percent = (value - minVal) / (maxVal - minVal)
				sliderFill.Size = UDim2.new(math.max(0, math.min(1, percent)), 0, 1, 0)
				valueLabel.Text = tostring(math.floor(value))
				if callback then
					callback(value)
				end
			end
			
			-- Mouse drag functionality
			local dragging = false
			sliderBg.InputBegan:Connect(function(input, gameProcessed)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					local mouse = UserInputService:GetMouseLocation()
					local sliderPos = sliderBg.AbsolutePosition.X
					local sliderSize = sliderBg.AbsoluteSize.X
					local percent = math.max(0, math.min(1, (mouse.X - sliderPos) / sliderSize))
					local value = minVal + (percent * (maxVal - minVal))
					updateSlider(value)
				end
			end)
			
			sliderBg.InputEnded:Connect(function(input, gameProcessed)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end)
			
			UserInputService.InputChanged:Connect(function(input, gameProcessed)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					local mouse = UserInputService:GetMouseLocation()
					local sliderPos = sliderBg.AbsolutePosition.X
					local sliderSize = sliderBg.AbsoluteSize.X
					local percent = math.max(0, math.min(1, (mouse.X - sliderPos) / sliderSize))
					local value = minVal + (percent * (maxVal - minVal))
					updateSlider(value)
				end
			end)
			
			updateSlider(defaultVal)
			return sliderBg
		end
		
