-- Particle spawn function
local function createParticle()
	local particle = Instance.new("TextLabel")
	particle.Name = "Particle"
	particle.Size = UDim2.new(0, math.random(15, 30), 0, math.random(15, 30))
	particle.Position = UDim2.new(math.random(0, 100) / 100, 0, math.random(0, 100) / 100, 0)
	particle.BackgroundTransparency = 1
	particle.BorderSizePixel = 0
	particle.Text = GLITCH_CHARS_PARTICLES[math.random(1, #GLITCH_CHARS_PARTICLES)]
	particle.TextColor3 = Color3.fromRGB(255, 255, 255)
	particle.TextSize = math.random(12, 20)
	particle.Parent = particleContainer
	particle.ZIndex = 2
	
	local startTransparency = math.random(10, 50) / 100
	particle.TextTransparency = startTransparency
	
	-- Animate particle
	spawn(function()
		local elapsed = 0
		local lifetime = math.random(3, 6)
		
		while elapsed < lifetime and particle.Parent do
			RunService.RenderStepped:Wait()
			elapsed = elapsed + RunService.RenderStepped:Wait()
			
			particle.TextTransparency = startTransparency + (elapsed / lifetime) * (1 - startTransparency)
		end
		
		if particle.Parent then
			particle:Destroy()
		end
	end)
end

-- Spawn particles continuously on window
spawn(function()
	while screenGui.Parent do
		createParticle()
		wait(0.15)
	end
end)

